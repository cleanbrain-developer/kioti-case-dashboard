generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Case {
  id          String    @id
  caseNumber  String    @map("case_number")
  subject     String?
  status      String?
  priority    String?
  department  String?
  picId       String?   @map("pic_id")
  picName     String?   @map("pic_name")
  moduleLevel String?   @map("module_level")
  accountName String?   @map("account_name")
  ownerId     String?   @map("owner_id")
  ownerName   String?   @map("owner_name")
  createdDate DateTime? @map("created_date")
  isClosed    Boolean   @default(false) @map("is_closed")
  syncedAt    DateTime  @default(now()) @map("synced_at")

  @@map("cases")
}

model DailyVisit {
  date  DateTime @id @db.Date
  count Int      @default(0)

  @@map("daily_visits")
}

model SyncLog {
  id          Int       @id @default(autoincrement())
  startedAt   DateTime  @default(now()) @map("started_at")
  endedAt     DateTime? @map("ended_at")
  totalSynced Int?      @map("total_synced")
  status      String    @default("running")
  errorMsg    String?   @map("error_msg")

  @@map("sync_log")
}

model EmailRecipient {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  name        String
  createdAt   DateTime @default(now()) @map("created_at")
  departments RecipientDepartment[]

  @@map("email_recipients")
}

model RecipientDepartment {
  recipientId Int    @map("recipient_id")
  department  String
  recipient   EmailRecipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@id([recipientId, department])
  @@map("recipient_departments")
}

model EmailSchedule {
  id           Int       @id @default(autoincrement())
  enabled      Boolean   @default(false)
  freq         String    @default("weekly")
  dayOfWeek    Int?      @map("day_of_week")
  dayOfMonth   Int?      @map("day_of_month")
  hourEst      Int       @default(8)  @map("hour_est")
  minuteEst    Int       @default(0)  @map("minute_est")
  updatedAt    DateTime  @updatedAt   @map("updated_at")
  lastSentAt   DateTime?              @map("last_sent_at")

  @@map("email_schedules")
}
