# ── Salesforce 인증 ─────────────────────────────────────
SF_DOMAIN=https://yourcompany.my.salesforce.com
SF_CLIENT_ID=your_connected_app_consumer_key
SF_CLIENT_SECRET=your_connected_app_consumer_secret
SF_USERNAME=your_email@company.com
SF_PASSWORD=yourPasswordPlusSecurityToken

# ── Salesforce API 버전 (기본값 v62.0) ───────────────────
SF_API_VERSION=v62.0

# ── 서버 포트 (기본값 3000) ──────────────────────────────
PORT=3000

# ── PostgreSQL (Docker Compose 사용 시) ──────────────────
# docker-compose.yml이 DATABASE_URL을 자동 주입합니다.
# 로컬 직접 실행 시에만 아래를 설정하세요.
# DATABASE_URL=postgresql://kioti:yourSecurePassword@localhost:5432/kioti_dashboard

# DB 패스워드 (docker-compose에서 POSTGRES_PASSWORD로 사용)
DB_PASSWORD=yourSecurePassword

# ※ 커스텀 필드명은 서버가 SF metadata에서 자동으로 탐색합니다.
#   별도로 설정할 필요 없습니다.
